# ============================================================================
# AgroGuard environment variables
# ----------------------------------------------------------------------------
# Copy this file to ".env" in the project root and fill in the values:
#     cp .env.example .env        (macOS / Linux)
#     copy .env.example .env      (Windows cmd)
# Never commit your real .env file.
# ============================================================================

# PostgreSQL connection string.
# Local example: postgresql://agroguard_user:agroguard_pass@localhost:5432/agroguard
DATABASE_URL=

# Session signing secret. Use any long, random string (e.g. run:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
SESSION_SECRET=

# OpenAI API key — powers AI disease detection, advisory chat and recommendations.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Node environment. Use "development" locally, "production" when deployed.
NODE_ENV=development

# Backend API port (optional locally — defaults to 8080 if unset).
PORT=8080
