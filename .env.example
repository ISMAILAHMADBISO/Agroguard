# ============================================================================
# AgroGuard environment variables
# ----------------------------------------------------------------------------
# Copy this file to ".env" in the project root and fill in the values:
#     cp .env.example .env        (macOS / Linux)
#     copy .env.example .env      (Windows cmd)
# Never commit your real .env file.
#
# On Vercel: do NOT use a .env file. Add each variable under
# Project → Settings → Environment Variables instead.
# ============================================================================

# ── Required ────────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# Local example: postgresql://agroguard_user:agroguard_pass@localhost:5432/agroguard
# Neon (production): copy the POOLED connection string from the Neon dashboard
#   (the host contains "-pooler"); it must include "?sslmode=require". Example:
#   postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/agroguard?sslmode=require
DATABASE_URL=

# Session signing secret. Use any long, random string (e.g. run:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
# REQUIRED in production — the server refuses to start without it.
SESSION_SECRET=

# ── AI (optional, but needed for AI features) ────────────────────────────────

# OpenAI API key — powers AI disease detection, advisory chat and recommendations.
# Get one at https://platform.openai.com/api-keys
# If omitted, the AI endpoints return a clear "AI is not configured" message and
# the rest of the platform keeps working.
OPENAI_API_KEY=

# ── Runtime ──────────────────────────────────────────────────────────────────

# Node environment. Use "development" locally, "production" when deployed.
# (Vercel sets this to "production" automatically.)
NODE_ENV=development

# Backend API port for LOCAL development (defaults to 8080 if unset).
# Not used on Vercel — serverless functions don't listen on a port.
PORT=8080

# ── Origins / CORS (production) ──────────────────────────────────────────────

# Your app's public URL(s). On Vercel the frontend and API share an origin, so
# set this to your production domain so cookie auth + CSRF protection work.
# On Vercel, VERCEL_URL / VERCEL_PROJECT_PRODUCTION_URL are detected automatically,
# so APP_URL is mainly needed when you add a custom domain.
#   Example: APP_URL=https://agroguard.com
APP_URL=

# Additional allowed browser origins (comma-separated), e.g. extra custom domains.
#   Example: ALLOWED_ORIGINS=https://www.agroguard.com,https://staging.agroguard.com
ALLOWED_ORIGINS=

# ── Advanced (optional) ──────────────────────────────────────────────────────

# Max DB connections per process. Keep small on serverless (Vercel + Neon).
DB_POOL_MAX=3

# Local-only: set to "true" to have the API process also serve the built
# frontend (single-origin local production preview). Used by `npm run start`.
SERVE_CLIENT=false
