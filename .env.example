# AgroGuard Environment Variables
# Copy this file to .env and fill in the values.

# ── Required ──────────────────────────────────────────────────────────────────

# Neon (or any PostgreSQL) database connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Secret used to sign session cookies — use a long random string in production
SESSION_SECRET=change-me-to-a-long-random-string

# ── AI Features (optional but recommended) ────────────────────────────────────

# OpenAI API key — enables disease detection + advisory chat
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ── CORS / CSRF ────────────────────────────────────────────────────────────────

# The primary URL your app is served from (used for CORS allowlist)
APP_URL=https://your-app.vercel.app

# Comma-separated list of additional trusted origins (custom domains, local dev)
ALLOWED_ORIGINS=https://agroguard.tech,https://www.agroguard.tech,http://localhost:5173

# ── Database connection pool ───────────────────────────────────────────────────

# Max DB connections per serverless function instance (keep low for Neon free tier)
DB_POOL_MAX=3
