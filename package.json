{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "scripts"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c green,cyan \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "pnpm --filter @workspace/api-server dev",
    "dev:web": "pnpm --filter @workspace/agroguard dev",
    "build": "pnpm run typecheck && pnpm -r build --if-present",
    "vercel-build": "pnpm --filter @workspace/agroguard build && node -e \"const fs=require('fs');const p=require('path');const src=p.join('artifacts','agroguard','dist','public');const dst=p.join('dist','public');fs.rmSync('dist',{recursive:true,force:true});fs.mkdirSync(dst,{recursive:true});fs.cpSync(src,dst,{recursive:true});console.log('Frontend copied to dist/public/');\"",
    "start": "cross-env NODE_ENV=production SERVE_CLIENT=true pnpm --filter @workspace/api-server start",
    "setup": "pnpm --filter @workspace/db push && pnpm --filter @workspace/scripts run setup",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm --filter @workspace/agroguard --filter @workspace/api-server --filter @workspace/mockup-sandbox --filter @workspace/scripts typecheck"
  },
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "@esbuild-kit/esm-loader": "npm:tsx@^4.21.0",
    "esbuild": "0.27.3"
  }
}